{
  "id": "openclaw-discord-status-line",
  "name": "OpenClaw Discord Status Line",
  "description": "Draft plugin that appends compact status metadata to Discord replies.",
  "activation": {
    "onStartup": false
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": false
      },
      "channels": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "discord"
        ]
      },
      "channelIds": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": []
      },
      "template": {
        "type": "string",
        "default": "-# *{duration} • ctx {ctx_pct} • {tokens} • tools:{tool_calls} • {model}*"
      },
      "fallbackTemplate": {
        "type": "string",
        "default": "-# *{duration} • tools:{tool_calls} • {model}*"
      },
      "includeWhenUnknown": {
        "type": "boolean",
        "default": true
      },
      "separator": {
        "type": "string",
        "default": "\n\n"
      },
      "diagnostics": {
        "type": "object",
        "additionalProperties": false,
        "default": {
          "enabled": false,
          "safeStructuralLogging": true
        },
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "safeStructuralLogging": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
